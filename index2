<script>
  // Custom cursor
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursorRing');
  let mx = 0, my = 0, rx = 0, ry = 0;

  document.addEventListener('mousemove', e => {
    mx = e.clientX; my = e.clientY;
    cursor.style.left = mx + 'px';
    cursor.style.top = my + 'px';
    cursor.classList.add('visible');
    ring.classList.add('visible');
  });

  document.addEventListener('mouseleave', () => {
    cursor.classList.remove('visible');
    ring.classList.remove('visible');
  });

  // Hover effect on interactive elements
  const hoverEls = document.querySelectorAll('a, button, .who-types span, .hero-pill, .sc');
  hoverEls.forEach(el => {
    el.addEventListener('mouseenter', () => {
      cursor.classList.add('hovering');
      ring.classList.add('hovering');
    });
    el.addEventListener('mouseleave', () => {
      cursor.classList.remove('hovering');
      ring.classList.remove('hovering');
    });
  });

  function animRing() {
    rx += (mx - rx) * 0.12;
    ry += (my - ry) * 0.12;
    ring.style.left = rx + 'px';
    ring.style.top = ry + 'px';
    requestAnimationFrame(animRing);
  }
  animRing();

  // Services grid stagger animation
  const scCards = document.querySelectorAll('.sc');
  const scObserver = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const idx = Array.from(scCards).indexOf(entry.target);
        setTimeout(() => entry.target.classList.add('sc-visible'), idx * 80);
        scObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  scCards.forEach(c => scObserver.observe(c));

  // Biz bar fill animation
  const bizBar = document.querySelector('.biz-bar-fill');
  if (bizBar) {
    bizBar.style.width = '0%';
    const bizObs = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) {
        setTimeout(() => { bizBar.style.width = '70%'; }, 200);
        bizObs.disconnect();
      }
    }, { threshold: 0.5 });
    bizObs.observe(bizBar);
  }

  // Problem cards stagger
  const probCards = document.querySelectorAll('.prob-card');
  const probObs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const idx = Array.from(probCards).indexOf(entry.target);
        setTimeout(() => entry.target.classList.add('pc-vis'), idx * 120);
        probObs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  probCards.forEach(c => probObs.observe(c));

  // Scroll reveal for other sections
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(entries => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });
  reveals.forEach(el => observer.observe(el));


  // Greeting animation trigger
  const greeting = document.querySelector('.calc-greeting');
  if (greeting) {
    const greetObs = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) {
        greeting.classList.add('playing');
        greetObs.disconnect();
      }
    }, { threshold: 0.5 });
    greetObs.observe(greeting);
  }

  // Revenue calculator
  const revenueSlider = document.getElementById('revenueSlider');

  function fmt(n) {
    if (n >= 1000000) return '$' + (n/1000000).toFixed(1).replace(/\.0$/,'') + 'M';
    if (n >= 1000) return '$' + (n/1000).toFixed(0) + 'K';
    return '$' + n.toLocaleString();
  }

  function updateCalc() {
    const rev = parseInt(revenueSlider.value);
    const cut = 40;
    const monthly = Math.round(rev * cut / 100);
    const annual = monthly * 12;

    document.getElementById('revenueVal').textContent = fmt(rev);
    document.getElementById('monthlyResult').textContent = fmt(monthly);
    document.getElementById('annualResult').textContent = fmt(annual);
    document.getElementById('revenueSubVal').textContent = fmt(rev);

    const revPct = (rev - 1000) / (500000 - 1000) * 100;
    revenueSlider.style.background = `linear-gradient(to right, #1a1714 ${revPct}%, rgba(26,23,20,0.1) ${revPct}%)`;
  }

  if (revenueSlider) {
    revenueSlider.addEventListener('input', updateCalc);
    updateCalc();
  }

</script>

