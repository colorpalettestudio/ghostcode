<script>
  // Timeline scroll animation
  const hiwSteps = document.querySelectorAll('.hiw-step');
  const hiwObs = new IntersectionObserver(entries => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), 150);
        hiwObs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });
  hiwSteps.forEach(s => hiwObs.observe(s));
</script>

