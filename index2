<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Ghostcode — We Build Software Products for Creators</title>
<link rel="icon" type="image/png" href="data:image/png;base64,">
<meta name="description" content="Ghostcode partners with creators to build apps and AI tools for their audience — with no upfront cost. We build it. You launch it." />
<meta property="og:title" content="Ghostcode — We Build Software Products for Creators" />
<meta property="og:description" content="Ghostcode partners with creators to build apps and AI tools for their audience — with no upfront cost. We build it. You launch it." />
<meta property="og:type" content="website" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="Ghostcode — We Build Software Products for Creators" />
<meta name="twitter:description" content="Ghostcode partners with creators to build apps and AI tools for their audience — with no upfront cost." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&family=Crimson+Pro:ital,wght@0,300;1,300&display=swap" rel="stylesheet" />
<style>
  @font-face {
    font-family: 'PerfectlyNineties';
    src: url('data:font/otf;base64,') format('opentype');
    font-weight: normal;
    font-style: normal;
  }
  @font-face {
    font-family: 'PerfectlyNineties';
    src: url('data:font/ttf;base64,') format('truetype');
    font-weight: normal;
    font-style: italic;
  }
  :root {
    --black: #1a1714;
    --white: #faf7f2;
    --ghost: #7a756e;
    --accent: #c8ff00;
    --dim: #f0ebe2;
    --border: rgba(26,23,20,0.1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--white);
    color: var(--black);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
    cursor: none;
  }

  ::selection {
    background: #C8FF00;
    color: #1a1714;
  }

  /* Custom cursor */
  .cursor {
    position: fixed;
    width: 12px; height: 12px;
    background: var(--black);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: width 0.2s ease, height 0.2s ease, background 0.2s ease;
    opacity: 0;
  }
  .cursor-ring { display: none; }
  .cursor.visible { opacity: 1; }
  .cursor.hovering {
    width: 8px; height: 8px;
    background: var(--accent);
  }


  /* Noise overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.025;
    pointer-events: none;
    z-index: 9000;
  }

  /* NAV */
  nav {
    position: static;
    z-index: 1000;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 28px 48px;
    border-bottom: 1px solid transparent;
    transition: border-color 0.4s, background 0.4s;
  }
  nav.scrolled {
    background: rgba(250,247,242,0.94);
    backdrop-filter: blur(12px);
    border-color: var(--border);
  }
  .nav-logo {
    font-family: 'Avantt', sans-serif;
    font-weight: 800;
    font-size: 18px;
    letter-spacing: -0.02em;
    color: var(--black);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .nav-logo-dot {
    width: 7px; height: 7px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2.5s ease infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }
  .nav-cta {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--black);
    background: var(--accent);
    padding: 10px 22px;
    text-decoration: none;
    text-transform: uppercase;
    border: 2px solid var(--black);
    transition: opacity 0.2s;
  }
  .nav-cta:hover { opacity: 0.85; }

  /* HERO */
  .hero {
    height: calc(100vh - 80px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 48px 48px;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 20%, rgba(200,255,0,0.18) 0%, transparent 65%);
  }

  .hero-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--black);
    text-transform: uppercase;
    margin-bottom: 36px;
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.2s forwards;
  }
  .hero-tag::before {
    content: '';
    width: 7px; height: 7px;
    background: var(--accent);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hero-headline {
    font-family: 'Avantt', sans-serif;
    font-weight: 800;
    font-size: clamp(47px, 7.15vw, 104px);
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--black);
    max-width: 1100px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.4s forwards;
  }
  .hero-highlight {
    display: inline-block;
    background: var(--accent);
    padding: 0 16px 6px;
    border-radius: 8px;
    color: var(--black);
    font-style: normal;
    font-family: 'Avantt', sans-serif;
    font-weight: 800;
  }



  .hero-sub-italic {
    margin-top: 32px;
    font-family: 'DM Sans', sans-serif;
    font-style: normal;
    font-size: clamp(18px, 2vw, 26px);
    font-weight: 300;
    color: rgba(26,23,20,0.65);
    max-width: 740px;
    line-height: 1.6;
    letter-spacing: 0;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.6s forwards;
  }

  .hero-sub {
    margin-top: 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(20px, 2vw, 28px);
    font-style: normal;
    font-weight: 300;
    color: rgba(26,23,20,0.55);
    max-width: 640px;
    white-space: normal;
    line-height: 1.7;
    letter-spacing: 0;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.7s forwards;
  }

  .hero-pills {
    margin-top: 32px;
    display: grid;
    grid-template-columns: repeat(4, auto);
    gap: 10px;
    justify-content: center;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.75s forwards;
  }
  .hero-pill {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    letter-spacing: 0.02em;
    color: var(--black);
    border: 1.5px solid var(--border);
    border-radius: 100px;
    padding: 10px 22px;
    background: #ffffff;
    text-align: center;
    white-space: nowrap;
  }

  .hero-actions {
    margin-top: 40px;
    display: flex;
    gap: 20px;
    align-items: center;
    justify-content: center;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.9s forwards;
  }

  .btn-primary {
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--black);
    padding: 24px 54px;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-primary:hover { opacity: 0.85; transform: translateY(-1px); }

  .btn-ghost {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(26,23,20,0.55);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: color 0.2s;
  }
  .btn-ghost::after { content: '↓'; }
  .btn-ghost:hover { color: var(--black); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }


  /* SECTIONS */
  section { padding: 120px 48px; }

  .section-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-label::before {
    content: '';
    display: block;
    width: 32px; height: 1px;
    background: var(--black);
  }
  .apply .section-label { color: var(--black); opacity: 0.6; }
  .apply .section-label::before { background: var(--black); opacity: 0.4; }

  .section-headline {
    font-family: 'Avantt', sans-serif;
    font-weight: 700;
    font-size: clamp(48px, 7vw, 100px);
    letter-spacing: -0.04em;
    line-height: 1.0;
    color: var(--black);
  }

  .section-headline em {
    font-style: italic;
    font-family: 'Perfectly Nineties', serif;
    font-weight: 300;
    color: #9a9188;
    letter-spacing: 0;
  }


  /* HOW IT WORKS */
  .how {
    background: var(--white); padding: 100px 52px 112px;
    border-top: 1px solid rgba(26,23,20,0.08);
  }
  .how-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(26,23,20,0.35); display: flex; align-items: center; gap: 12px;
    margin-bottom: 64px; justify-content: center;
  }
  .how-label::before, .how-label::after { content: ''; width: 32px; height: 1px; background: rgba(26,23,20,0.15); }
  .how-steps {
    display: flex; align-items: center; justify-content: center;
    gap: 0; max-width: 900px; margin: 0 auto;
  }
  .how-step {
    flex: 1; display: flex; flex-direction: column; align-items: center;
    text-align: center; max-width: 240px;
  }
  .how-step-illo {
    width: 160px; height: 144px; margin-bottom: 28px;
  }
  .how-step-illo svg { width: 100%; height: 100%; }
  .how-step-num {
    font-size: 10px; font-weight: 700; letter-spacing: 0.16em;
    color: rgba(26,23,20,0.25); margin-bottom: 10px;
  }
  .how-step-title {
    font-family: 'Avantt', sans-serif; font-weight: 800; font-size: 17px;
    text-transform: uppercase; letter-spacing: 0; color: var(--black);
    line-height: 1.15; margin-bottom: 12px;
  }
  .how-step-body {
    font-size: 13px; color: rgba(26,23,20,0.5); line-height: 1.75;
  }
  .how-connector {
    flex-shrink: 0; width: 60px; margin-bottom: 80px; opacity: 0.6;
  }
  @media (max-width: 760px) {
    .how-steps { flex-direction: column; gap: 48px; }
    .how-connector { transform: rotate(90deg); margin-bottom: 0; }
    .how { padding-left: 24px; padding-right: 24px; }
  }

  /* PROBLEM */
  /* PROBLEM */
  .problem {
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: start;
  }
  .problem-left { position: sticky; top: 120px; }
  .problem-headline {
    font-family: 'Avantt', sans-serif;
    font-weight: 800;
    font-size: clamp(36px, 4.5vw, 60px);
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--black);
    margin-top: 24px;
  }
  .problem-headline em {
    font-family: 'Perfectly Nineties', serif;
    font-style: italic;
    font-weight: 300;
    color: var(--ghost);
    letter-spacing: 0;
  }
  .problem-body {
    font-size: 17px;
    color: rgba(26,23,20,0.6);
    line-height: 1.9;
    margin-top: 24px;
    max-width: 340px;
  }
  /* Problem cards */
  .problem-cards {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .prob-card {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px 28px 28px 28px;
    background: #f0ebe2;
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease, border-color 0.3s, background 0.3s;
  }
  .prob-card.pc-vis { opacity: 1; transform: translateY(0); }
  .prob-card:hover { border-color: rgba(26,23,20,0.18); background: #e8e3da; }
  .prob-card-solution {
    border-color: var(--accent);
    background: var(--accent);
  }
  .prob-card-solution:hover { border-color: var(--accent); background: var(--accent); }
  .prob-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 12px;
    gap: 16px;
  }
  .prob-card-title {
    font-family: 'Avantt', sans-serif;
    font-weight: 700;
    font-size: 17px;
    letter-spacing: -0.01em;
    color: var(--black);
    line-height: 1.2;
  }
  .prob-card-solution .prob-card-title { color: var(--black); }
  .prob-card-num {
    font-family: 'DM Sans', sans-serif;
    font-size: 28px;
    font-weight: 300;
    color: rgba(26,23,20,0.12);
    line-height: 1;
    flex-shrink: 0;
    letter-spacing: -0.03em;
  }
  .prob-card-solution .prob-card-num { color: transparent; } /* replaced by ghost svg */
  .prob-card-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: rgba(26,23,20,0.6);
    line-height: 1.85;
  }
  .prob-card-solution .prob-card-desc { color: rgba(26,23,20,0.7); }
  .prob-card-ghost-icon { width: 24px; height: auto; opacity: 0.3; flex-shrink: 0; }

  @media (max-width: 900px) {
    .problem { grid-template-columns: 1fr; gap: 48px; }
    .problem-left { position: static; }
  }

  /* SERVICES / LIFECYCLE */
  .services {
    border-top: 1px solid var(--border);
    background: var(--white);
  }
  .services-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 80px;
  }
  .services-intro {
    font-size: 17px;
    color: var(--black);
    opacity: 0.55;
    max-width: 340px;
    line-height: 1.8;
    text-align: right;
  }

  /* SERVICES GRID */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
  }
  .sc {
    background: #ffffff;
    padding: 40px 28px 36px;
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease, background 0.3s;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .sc.sc-visible { opacity: 1; transform: translateY(0); }
  .sc:hover { background: #f7f5f2; }
  .sc::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
  }
  .sc:hover::after { transform: scaleX(1); }
  .sc-illo {
    width: 45px; height: 45px;
    margin-bottom: 24px;
    position: relative;
    flex-shrink: 0;
  }
  .sc-illo svg { width: 100%; height: 100%; overflow: visible; }
  .sc-num {
    font-family: 'DM Sans', sans-serif;
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--black);
    opacity: 0.4;
    margin-bottom: 12px;
    display: block;
  }
  .sc-title {
    font-family: 'Avantt', sans-serif;
    font-weight: 700;
    font-size: 22px;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 12px;
    line-height: 1.15;
  }
  .sc-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: rgba(26,23,20,0.6);
    line-height: 1.9;
  }

  /* PRODUCTS */
  .products {
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
    padding-bottom: 0;
  }
  .products-top {
    position: sticky;
    top: 120px;
  }
  .products-sub {
    font-family: 'Perfectly Nineties', serif;
    font-style: italic;
    font-size: 20px;
    color: rgba(26,23,20,0.55);
    font-weight: 300;
    letter-spacing: 0;
    max-width: 300px;
    line-height: 1.6;
    text-align: left;
    margin-top: 20px;
  }
  .build-list {
    border-top: 1px solid var(--border);
  }
  .build-item {
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    cursor: default;
    position: relative;
  }
  .build-item-inner {
    display: flex;
    align-items: center;
    gap: 28px;
    width: 100%;
    padding: 24px 0;
    transition: padding 0.4s ease;
  }
  .build-item:hover .build-item-inner { padding: 24px 20px; }
  .build-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
    z-index: 0;
  }
  .build-item:hover::before { transform: scaleX(1); }
  .build-num {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--ghost);
    min-width: 28px;
    position: relative;
    z-index: 1;
    transition: color 0.3s;
  }
  .build-item:hover .build-num { color: rgba(26,23,20,0.45); }
  .build-name {
    font-family: 'Avantt', sans-serif;
    font-weight: 700;
    font-size: 22px;
    letter-spacing: 0;
    color: var(--black);
    position: relative;
    z-index: 1;
    transition: color 0.3s;
    line-height: 1;
  }
  .build-item:hover .build-name { color: var(--black); }
  .build-tag {
    margin-left: auto;
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--black);
    opacity: 0;
    position: relative;
    z-index: 1;
    transform: translateX(10px);
    transition: opacity 0.3s, transform 0.3s, color 0.3s;
    white-space: nowrap;
  }
  .build-item:hover .build-tag { opacity: 1; transform: translateX(0); color: rgba(26,23,20,0.55); }
  .products-footer {
    padding: 48px 0 0;
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .products-footer-line { flex: 1; height: 1px; background: var(--border); }
  .products-footer-text {
    font-family: 'Perfectly Nineties', serif;
    font-style: italic;
    font-size: 18px;
    color: rgba(26,23,20,0.55);
    white-space: nowrap;
    letter-spacing: 0;
  }

  /* BUSINESS MODEL */
  .biz {
    border-top: 1px solid var(--border);
    background: var(--white);
    padding: 120px 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .biz-left { position: sticky; top: 120px; }
  .biz-headline {
    font-family: 'Avantt', sans-serif;
    font-weight: 800;
    font-size: clamp(36px, 4.5vw, 58px);
    letter-spacing: -0.03em;
    line-height: 1.0;
    color: var(--black);
    margin-top: 24px;
    margin-bottom: 28px;
  }
  .biz-headline em {
    font-family: 'Perfectly Nineties', serif;
    font-style: italic;
    font-weight: 300;
    color: #9a9188;
    letter-spacing: 0;
  }
  .biz-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    color: rgba(26,23,20,0.6);
    line-height: 1.9;
    margin-bottom: 40px;
    max-width: 420px;
  }
  .biz-points {
    display: flex;
    flex-direction: column;
    gap: 24px;
    list-style: none;
  }
  .biz-point {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }
  .biz-check {
    width: 28px; height: 28px;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 11px;
    color: var(--accent);
    margin-top: 1px;
  }
  .biz-point-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: rgba(26,23,20,0.7);
    line-height: 1.75;
  }
  .biz-point-text strong {
    font-weight: 600;
    color: var(--black);
  }

  /* Revenue card */
  .biz-card {
    background: var(--dim);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 40px;
  }
  .biz-card-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.2em;
